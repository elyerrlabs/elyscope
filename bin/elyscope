#!/usr/bin/env php
<?php
declare(strict_types=1);

require_once __DIR__ . "/../vendor/autoload.php";

use Symfony\Component\Filesystem\Filesystem;

$fs = new Filesystem();
$basePath = getcwd();


//Checking composer file
if (!file_exists($basePath . "/composer.json")) {
    throw new RuntimeException("composer.json not found in " . $basePath);
}

$source = __DIR__ . '/../resources/installed-package.php';
$target = $basePath . '/installed-package.php';

if (!file_exists($target)) {
    copy($source, $target);
}

$command = $args[0] ?? '';
$args = array_slice($argv, 1);

main();

function main(): void
{
    global $args;

    if (
        empty($args) ||
        in_array('--help', $args, true) ||
        in_array('-h', $args, true) ||
        in_array('help', $args, true)
    ) {
        help();
    }

    $command = $args[0] ?? '';

    switch ($command) {

        case 'install':
            install();
            break;

        case 'update':
            update();
            break;

        case 'require':
        case 'remove':
            packageOperation();
            break;

        default:
            run('composer ' . implode(' ', $args));
            exit(0);
    }
}

/// ---------Functions---------------////
function packageOperation(): void
{
    global $args;
    global $fs;

    if (!is_dir('vendor-packsave')) {
        throw new RuntimeException(
            'vendor-packsave not found. Run elymod install first.'
        );
    }

    $fs->remove('vendor');

    $fs->mirror('vendor-packsave', 'vendor');

    $command = implode(' ', $args);

    run("composer {$command} --no-scripts");

    installPipeline();

    echo "\nPackage operation completed successfully !!!\n";

    exit(0);
}

function install(): void
{
    global $args;

    preInstall();

    $options = implode(' ', array_slice($args, 1));

    run(
        'composer install ' .
        $options .
        ' --no-scripts'
    );

    installPipeline();

    echo "\nDependencies installed successfully !!!\n";

    exit(0);
}


function update(): void
{
    global $args;

    preUpdate();

    $options = implode(' ', array_slice($args, 1));

    run(
        'composer update ' .
        $options .
        ' --no-scripts'
    );

    updatePipeline();

    echo "\nDependencies updated successfully !!!\n";

    exit(0);
}


/**
 * Run command
 * @param string $cmd
 * @throws RuntimeException
 * @return void
 */
function run(string $cmd): void
{
    global $basePath;

    echo "\n $cmd \n";

    $process = proc_open($cmd, [0 => STDIN, 1 => STDOUT, 2 => STDERR], $pipes, $basePath);

    if (!is_resource($process)) {
        throw new RuntimeException("Unable to execute: $cmd");
    }

    $code = proc_close($process);

    if ($code !== 0) {
        throw new RuntimeException("Failed : $cmd");
    }
}


function composerInstallProd()
{
    run("composer install --no-dev --no-scripts");
}

function composerInstallDev()
{
    run("composer install --no-scripts");
}

function composerUpdateProd()
{
    run('composer update --no-dev --no-scripts');
}

function composerUpdateDev()
{
    run("composer update --no-scripts");
}

/**
 * Pre install
 * @return void
 */
function preInstall(): void
{
    global $fs;

    echo "Preparing install...\n";

    if (is_dir("vendor")) {
        $fs->remove("vendor");
    }

    if (is_dir('vendor-packsave')) {
        $fs->remove("vendor-packsave");
    }

    if (is_dir('vendor-build')) {
        $fs->remove("vendor-build");
    }
}

function preUpdate(): void
{
    global $fs;

    echo "Preparing update...\n";

    if (!is_dir("vendor") || !is_dir('vendor-packsave')) {
        echo "First install packages\n";
        exit;
    }

    $fs->remove("vendor");
    $fs->mirror("vendor-packsave", "vendor");
}

function phpScoperBinary(): string
{
    return __DIR__ . '/../vendor/bin/php-scoper';
}

function installPipeline(): void
{
    global $fs;

    echo "Running install pipeline...\n";

    run(phpScoperBinary() . " add-prefix --force");

    $fs->mirror("vendor", "vendor-packsave");

    $fs->remove("vendor");

    $fs->mirror("vendor-build", "vendor");

    $fs->remove("vendor-build");

    dumpPipeline();

    run("composer dumpautoload -o");
}

function updatePipeline(): void
{
    global $fs;

    echo "Running update pipeline...\n";

    $fs->remove("vendor-packsave");

    $fs->mirror("vendor", "vendor-packsave");

    run(phpScoperBinary() . " add-prefix --force");

    $fs->remove("vendor");

    $fs->mirror("vendor-build", "vendor");

    $fs->remove("vendor-build");

    dumpPipeline();

    run("composer dumpautoload -o");
}

function dumpPipeline(): void
{
    echo "Finalizing autoload...\n";
    run("php installed-package.php");
}

function installProd(): void
{
    preInstall();
    composerInstallProd();
    installPipeline();
    echo "\nDependencies installed successfully !!!\n";
    exit(0);
}

function installDev(): void
{
    preInstall();
    composerInstallDev();
    installPipeline();

    echo "\nDependencies updated successfully !!!\n";
    exit(0);
}

function updateProd(): void
{
    preUpdate();
    composerUpdateProd();
    updatePipeline();
    echo "\nDependencies updated successfully !!!\n";
    exit(0);
}

function updateDev(): void
{
    preUpdate();
    composerUpdateDev();
    updatePipeline();

    echo "\nDependencies updated successfully !!!\n";
    exit(0);
}


function help(): void
{
    echo <<<TXT

ElyMod Package Manager
======================

Usage:
  elymod <command> [options]

Commands
--------

  install
      Install dependencies in development mode.

      Workflow:
      - Remove vendor
      - Composer install
      - Run PHP-Scoper
      - Create vendor-packsave backup
      - Replace vendor with vendor-build
      - Update installed.json
      - Generate optimized autoload

  install --no-dev
      Install production dependencies only.

  update
      Update dependencies in development mode.

      Workflow:
      - Restore vendor from vendor-packsave
      - Composer update
      - Refresh vendor-packsave
      - Run PHP-Scoper
      - Replace vendor with vendor-build
      - Update installed.json
      - Generate optimized autoload

  update --no-dev
      Update production dependencies only.

  dump
      Regenerate ElyMod autoload metadata.

      Workflow:
      - Update installed.json
      - Composer dump-autoload -o

  help
  --help
  -h
      Display this help screen.

Composer passthrough
--------------------

Any unsupported command will be forwarded to Composer.

Examples:

  elymod require monolog/monolog
  elymod remove monolog/monolog
  elymod show
  elymod outdated
  elymod validate
  elymod why laravel/framework

Directories
-----------

  vendor/
      Scoped dependencies used by the project.

  vendor-packsave/
      Clean backup of original Composer dependencies.

  vendor-build/
      Temporary PHP-Scoper output directory.

TXT;

    exit(0);
}
